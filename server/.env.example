# Firebase Admin — paste the full JSON from serviceAccountKey.json as a single line
GOOGLE_CREDENTIALS=

# Discord OAuth — from discord.com/developers > your app > OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_TOKEN=
# Must match exactly what you set in the Discord app's Redirect URIs
DISCORD_REDIRECT_URI=https://your-backend.onrender.com/auth/discord/callback
DISCORD_GUILD_ID=

# ID of the Discord channel where task assignment mentions are posted (e.g. #task-notifications)
# Right-click the channel in Discord > Copy Channel ID (requires Developer Mode)
# Leave blank to skip channel mentions — DMs will still be sent
DISCORD_NOTIFICATION_CHANNEL_ID=

# Resend — from resend.com/api-keys
RESEND_API_KEY=
# Verified sender domain once you set one up in Resend dashboard
# During development, 'TaskFlow <onboarding@resend.dev>' works without domain verification
EMAIL_FROM=TaskFlow <onboarding@resend.dev>

# Your Vercel frontend URL (no trailing slash) — used for CORS, OAuth redirects, email links
FRONTEND_URL=https://taskflow-pm-lovat.vercel.app

# Comma-separated extra origins permitted by CORS (e.g. preview deployments)
EXTRA_ALLOWED_ORIGINS=

PORT=3001

# Standard Node env. Production mode hardens cookies and requires GOOGLE_CREDENTIALS.
NODE_ENV=development

# Dev only: set to '1' to load credentials from serviceAccountKey.json next to db.js
# instead of GOOGLE_CREDENTIALS. Never enable in production.
ALLOW_SERVICE_ACCOUNT_FILE=
