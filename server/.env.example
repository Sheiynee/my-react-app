# Firebase Admin — paste the full JSON from serviceAccountKey.json as a single line
GOOGLE_CREDENTIALS=

# Discord OAuth — from discord.com/developers > your app > OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must match exactly what you set in the Discord app's Redirect URIs
DISCORD_REDIRECT_URI=https://your-backend.onrender.com/auth/discord/callback

# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://taskflow-pm-lovat.vercel.app

PORT=3001
